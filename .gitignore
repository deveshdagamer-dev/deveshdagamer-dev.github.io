# ============================================================================
# Hugo Site .gitignore
# ============================================================================

# ============================================================================
# Hugo Build Artifacts
# ============================================================================

# Generated site output
public/
!public/
public/*
!public/assets/
public/assets/*
!public/assets/research/
!public/assets/research/*
!public/assets/videos/
!public/assets/videos/*

# Hugo resources (processed assets)
resources/

# Hugo build lock
.hugo_build.lock

# Hugo stats
hugo_stats.json

# Auto-generated JS config
**/assets/jsconfig.json

# ============================================================================
# Node.js & Package Managers
# ============================================================================

# Dependencies
node_modules/

# ============================================================================
# Environment & Configuration
# ============================================================================

# Environment variables
.env
.env.local
.env.production
.env.*
.env.*.local
!.env.example

# Private local configuration
*.local
*.secret
*.secrets
secrets/
private/
*.pem
*.key

# ============================================================================
# Generated Content
# ============================================================================

# Pagefind search index
pagefind/
static/pagefind/

# Cache files
.cache/
cache/
.parcel-cache/
.turbo/
.vite/
.next/
.netlify/

# Generated website audit reports
reports/latest-website-audit.md
!reports/.gitkeep

# ============================================================================
# Operating System
# ============================================================================

# macOS
.DS_Store
.DS_Store?
._*

# Windows
Thumbs.db
Desktop.ini

# Linux
*~

# ============================================================================
# Logs & Temporary Files
# ============================================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
